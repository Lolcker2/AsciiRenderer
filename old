    @staticmethod
    def blend(matrix1, matrix2, pos):
        finalmatrix = matrix1
        for y in range(len(matrix2)):
            for x in range(len(matrix2[0])):
                finalmatrix[pos[1] + y][pos[0] + x] = matrix2[y][x]
        return finalmatrix

    @staticmethod
    def printing(screen, self, printcolor, spacing, size):
        txtlist = []
        for line in range(len(self)):
            for item in range(len(self[line])):
                if self[line][item] != 0:
                    txtlist.append(Text(str(self[line][item]), size, printcolor, item * spacing, line * spacing, align='center'))
        for text in txtlist:
            text.draw(screen)
    
    @staticmethod
    def finalprinting(matrix, printcolor, spacing, size):
