        cgengine.printing(var1, printcolor, spacing, size)
    
    @staticmethod
    def clear(matrix, x1, y1, x2, y2):
        for y in range(y1, y2 + 1):
            for x in range(x1, x2 + 1):
                matrix[y][x] = 0
        return matrix

    @staticmethod
    def create(size):
        finalmatrix = []
        for y in range(size[1]):
            temp = []
            for x in range(size[0]):
                temp.append(" ")          # space and zero are both count as blank enteties.
            finalmatrix.append(temp)
        return finalmatrix

