from pygame import *


class Text:
    def __init__(self, text, size, clr, x, y, align='nw', font_='hack'):
        self.text = text
        self.size = size
        self.clr = clr
        self.x = x
        self.y = y
        self.align = align
        self.font = font_

    def draw(self, thescreen):
        font_name = font.match_font(self.font)
        fn = font.Font(font_name, self.size)
        text_surface = fn.render(self.text, True, self.clr)
        text_rect = text_surface.get_rect()
        if self.align == "nw":
            text_rect.topleft = (self.x, self.y)
        if self.align == "ne":
            text_rect.topright = (self.x, self.y)
        if self.align == "sw":
            text_rect.bottomleft = (self.x, self.y)
        if self.align == "se":
            text_rect.bottomright = (self.x, self.y)
        if self.align == "n":
            text_rect.midtop = (self.x, self.y)
        if self.align == "s":
            text_rect.midbottom = (self.x, self.y)
        if self.align == "e":
            text_rect.midright = (self.x, self.y)
        if self.align == "w":
            text_rect.midleft = (self.x, self.y)
        if self.align == "center":
            text_rect.center = (self.x, self.y)
        thescreen.blit(text_surface, text_rect)


